# Database Configuration
# SQLite connection URL with asyncpg driver for async operations
DATABASE_URL=sqlite+aiosqlite:///./ai_travel_planner.db

# Memory Storage Configuration
# For in-memory storage, we can use a simple dictionary or a more complex solution like Redis or PostgreSQL.
MEMORY_DB_URL=sqlite+aiosqlite:///./memory_storage.db

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
APP_NAME=AI Travel Planner
APP_VERSION=1.0.0
DEBUG=False
APP_DESCRIPTION=An AI-powered travel planning service
PORT=8000
HOST=0.0.0.0
# SEED_DATABASE=true
