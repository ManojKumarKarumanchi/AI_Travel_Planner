# =============================================================================
# AI Travel Planner - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (Required)
# -----------------------------------------------------------------------------

# NVIDIA AI Endpoints - Get free API key at https://build.nvidia.com/explore/discover
# Models available: meta/llama-3.1-405b-instruct, meta/llama-3.1-70b-instruct (recommended), meta/llama-3.1-8b-instruct
NVIDIA_API_KEY=nvapi-your-key-here

# Serper (Google Search) - Get free key at https://serper.dev (2,500 free queries)
SERPER_API_KEY=your_serper_key_here

# -----------------------------------------------------------------------------
# API Keys (Optional - have fallbacks)
# -----------------------------------------------------------------------------

# ExchangeRate API - Get free key at https://www.exchangerate-api.com (1,500/month free)
# If not set, mock exchange rates will be used
EXCHANGERATE_API_KEY=your_exchangerate_key_here

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------

# NVIDIA model to use (default: meta/llama-3.1-70b-instruct)
# Options:
#   - meta/llama-3.1-405b-instruct  (best quality, slower)
#   - meta/llama-3.1-70b-instruct   (balanced, recommended)
#   - meta/llama-3.1-8b-instruct    (fast, cheaper)
#   - mistralai/mixtral-8x7b-instruct-v0.1
NVIDIA_MODEL="nvidia/nemotron-3-ultra-550b-a55b"


# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# SQLite connection URL with aiosqlite driver for async operations
DATABASE_URL=sqlite+aiosqlite:///./ai_travel_planner.db

# Memory Storage Configuration
MEMORY_DB_URL=sqlite+aiosqlite:///./memory_storage.db

# -----------------------------------------------------------------------------
# JWT Authentication (Optional - currently not enforced)
# -----------------------------------------------------------------------------

# Generate secure key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_generate_with_command_above
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

APP_NAME=AI Travel Planner
APP_VERSION=1.0.0
APP_DESCRIPTION=Multi-agent travel planning with human-in-the-loop approval
DEBUG=False
PORT=8000
HOST=0.0.0.0

# Optional: Seed database with demo users on startup
# SEED_DATABASE=true
